<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Airbnb Data Analysis</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
    <link rel="stylesheet" href="/styles.css">


</head>
<body class="bg-light">

    <div class="container py-5">
        <h1 class="text-center mb-4">Airbnb Database Analysis Project</h1>
        <p class="text-center text-muted"></p>

        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-primary text-white">1. Do Superhosts charge higher prices?</div>
            <div class="card-body">
                <table class="table table-striped">
                    <thead><tr><th>Is Superhost?</th><th>Average Price ($)</th></tr></thead>
                    <tbody>
                        <% q1.forEach(row => { %>
                            <tr>
                                <td><%= row.is_superhost == 1 ? 'Yes' : 'No' %></td>
                                <td><%= parseFloat(row.average_price).toFixed(2) %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-success text-white">2. Average Price by Neighbourhood</div>
            <div class="card-body">
                <ul class="list-group">
                    <% q2.forEach(row => { %>
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <%= row.neighbourhood_name %>
                            <span class="badge bg-success rounded-pill">$<%= parseFloat(row.average_price).toFixed(2) %></span>
                        </li>
                    <% }) %>
                </ul>
            </div>
        </div>

        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-info text-white">3. Correlation: Review Score vs Price</div>
            <div class="card-body">
                <p class="lead">
                    Average Review Score: <strong><%= parseFloat(q3[0].avg_review_score).toFixed(2) %></strong> <br>
                    Average Listing Price: <strong>$<%= parseFloat(q3[0].avg_price).toFixed(2) %></strong>
                </p>
            </div>
        </div>

        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-warning text-dark">4. Hosts with the most listings</div>
            <div class="card-body">
                <table class="table">
                    <thead><tr><th>Host Name</th><th>Listings Count</th></tr></thead>
                    <tbody>
                        <% q4.forEach(row => { %>
                            <tr>
                                <td><%= row.host_name %></td>
                                <td><%= row.number_of_listings %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>

        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-danger text-white">5. Room Type Impact on Pricing</div>
            <div class="card-body">
                <div class="row">
                    <% q5.forEach(row => { %>
                        <div class="col-md-4 text-center">
                            <div class="border p-3 rounded">
                                <h5><%= row.room_type %></h5>
                                <h3 class="text-danger">$<%= parseFloat(row.average_price).toFixed(2) %></h3>
                            </div>
                        </div>
                    <% }) %>
                </div>
            </div>
        </div>

        <div class="card mb-4 shadow-sm">
            <div class="card-header bg-warning text-dark">6. Best Value Listings</div>
            <div class="card-body">
                <table class="table">
                    <thead><tr><th>Host Name</th><th>Neighbourhood Name</th><th>Room Type</th><th>Price</th><th>Review Score</th></tr></thead>
                    <tbody>
                        <% q6.forEach(row => { %>
                            <tr>
                                <td><%= row.host_name %></td>
                                <td><%= row.neighbourhood_name %></td>
                                <td><%= row.room_type %></td>
                                <td><%= parseFloat(row.price).toFixed(2) %></td>
                                <td><%= parseFloat(row.review_score).toFixed(2) %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        </div>


        <div id="map" style="height:500px;"></div>

    </div>
    <!-- Hidden div to store JSON data -->
<div id="ward-data" data-json='<%= JSON.stringify(q2.map(r => ({
                            neighbourhood_name: r.neighbourhood_name,
                            average_price: parseFloat(r.average_price)}))) %>'
                             style="display:none;">

</div>

<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>
<script src="/wardLayer.js"></script>
<script src="/map.js"></script>

</body>
</html>